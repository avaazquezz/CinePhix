# CinePhix Frontend Environment Variables

# Backend API URL — debe ser una URL que el NAVEGADOR pueda resolver (localhost / 127.0.0.1 / dominio real).
# Nunca uses el hostname de un servicio Docker (p. ej. http://backend:8000): en el navegador falla con ERR_NAME_NOT_RESOLVED.
# Ajusta el puerto al que mapees tu API en el host (p. ej. 8000, 8081).
VITE_API_URL=http://127.0.0.1:8000

# TMDB API Key (for client-side poster images - uses existing key from backend)
VITE_TMDB_API_KEY=e546f0210838c597382ddcad9f8e0647