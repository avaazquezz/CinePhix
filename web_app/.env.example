# CinePhix Frontend Environment Variables

# Backend API URL — debe ser una URL que el NAVEGADOR pueda resolver (localhost / 127.0.0.1 / dominio real).
# Nunca uses el hostname de un servicio Docker (p. ej. http://backend:8001): en el navegador falla con ERR_NAME_NOT_RESOLVED.
# CinePhix en Docker suele exponerse en el host en 8001 (API_HOST_PORT); /docs en ese puerto = FastAPI de CinePhix.
VITE_API_URL=http://127.0.0.1:8001

# TMDB API Key (for client-side poster images - uses existing key from backend)
VITE_TMDB_API_KEY=